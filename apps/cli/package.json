{
  "name": "@fakeware/cli",
  "version": "0.0.8",
  "description": "The Fakeware cli",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fakeware-sh/fakeware.git",
    "directory": "apps/cli"
  },
  "engines": {
    "node": ">=22.6",
    "bun": ">=1.3.14"
  },
  "bin": {
    "fakeware": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./init": {
      "types": "./dist/init.d.mts",
      "import": "./dist/init.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@clack/prompts": "1.4.0",
    "@fakeware/core": "workspace:*",
    "commander": "14.0.3",
    "magicast": "0.5.3",
    "picocolors": "1.1.1",
    "terminal-link": "5.0.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "22.19.19"
  }
}
