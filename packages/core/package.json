{
  "name": "@fakeware/core",
  "version": "0.0.3",
  "description": "Fakeware core library that is the base for @fakeware/cli",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fakeware-sh/fakeware.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=22.6",
    "bun": ">=1.3.14"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config/index.d.mts",
      "import": "./dist/config/index.mjs"
    },
    "./shopware": {
      "types": "./dist/shopware/index.d.mts",
      "import": "./dist/shopware/index.mjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.mts",
      "import": "./dist/testing/index.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@shopware/api-client": "1.5.0",
    "jiti": "2.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "22.19.19"
  }
}
